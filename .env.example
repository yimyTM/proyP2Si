APP_NAME="FICCT Admisión"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Idioma de mensajes (recuperación de contraseña, validaciones)
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=proysiparcial2
DB_USERNAME=root
# DB_PASSWORD=tu_contraseña_de_postgresql

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# ─── Correo (recuperación de contraseña) ─────────────────────────────────────
#
# OPCIÓN A – Desarrollo sin SMTP (recomendado para probar en local):
#   El correo no se envía; el enlace de recuperación se escribe en el log.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@ficct.uagrm.edu.bo"
MAIL_FROM_NAME="${APP_NAME}"

# OPCIÓN B – Gmail (cuenta con verificación en 2 pasos + contraseña de aplicación):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu_correo@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="${MAIL_USERNAME}"
# MAIL_FROM_NAME="${APP_NAME}"

# OPCIÓN C – Outlook / Hotmail:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USERNAME=tu_correo@outlook.com
# MAIL_PASSWORD=tu_contraseña_o_app_password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="${MAIL_USERNAME}"
# MAIL_FROM_NAME="${APP_NAME}"

# OPCIÓN D – Mailtrap (pruebas, no envía correos reales): https://mailtrap.io
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=tu_usuario_mailtrap
# MAIL_PASSWORD=tu_password_mailtrap
# MAIL_FROM_ADDRESS="noreply@ficct.test"
# MAIL_FROM_NAME="${APP_NAME}"

MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

VITE_APP_NAME="${APP_NAME}"
